# Supabase — obter em: https://app.supabase.com → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# CLI: supabase login grava token; ou defina access token (Settings → Access Tokens)
# SUPABASE_ACCESS_TOKEN=

# Migrations locais: senha do Postgres (Settings → Database → Database password)
# Projeto: pentaClaude — ref ikielkwgixbdzrwixtos
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:SENHA@db.ikielkwgixbdzrwixtos.supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Agente IA lateral (Pentagrama) — desativado por padrão; true para reativar
NEXT_PUBLIC_AGENT_ENABLED=false

# Modelo comercial V2 — consultor licenciado único (slots por consultant_id)
# false = legado (leader pagante); true = ativar após validar em staging
NEXT_PUBLIC_LICENSING_V2=false

# PDF NR-01 (dev) — opcional; vazio = detecta Chrome/Edge no Windows/Mac/Linux
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Landing NR-01
NEXT_PUBLIC_JOVANE_CRP=CRP 16/4948

# HMAC-SHA256 do IP em leads LP (nunca commitar valor real). Gerar: openssl rand -hex 32
LEAD_HMAC_SECRET=

# IA — Groq (geração de texto) + OpenAI (embeddings)
GROQ_API_KEY=sua_groq_api_key_aqui
OPENAI_API_KEY=sua_openai_api_key_aqui

# === Email (Resend — Pentagrama + NR-01 + convites) ===
# Sem RESEND_API_KEY, sistema cai em modo 'console' (não envia emails reais).
# Pegar em https://resend.com/api-keys após verificar domínio (ex.: mail.quantun5g.com.br).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Resend → POST /api/webhooks/resend (produção: https://quantun5g.app/api/webhooks/resend)
# Dashboard Resend → Webhooks → signing secret (whsec_...). Só Vercel + .env.local — nunca no client.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetentes (domínio verificado no Resend)
QUANTUM_EMAIL_FROM=Quantum5G <convites@mail.seudominio.com.br>
PENTAGRAMA_EMAIL_FROM=Quantum5G Pentagrama <convites@mail.seudominio.com.br>
NR01_EMAIL_FROM=Quantum5G NR-01 <convites@mail.seudominio.com.br>

# Dev: força Resend localmente (NÃO definir em produção/Vercel)
# EMAIL_USE_RESEND_IN_DEV=true

# === NR-01 Pseudonimização (HMAC-SHA256) ===
# Chaves secretas para pseudonimização de IP e email no audit log e tabela
# de convites. Conformidade Art. 13 LGPD (pseudonimização forte).
#
# Gerar localmente com: openssl rand -hex 32
# Adicionar em Vercel: Settings → Environment Variables → Production → Sensitive.
# NUNCA commitar valores reais. Sem essas variáveis, o sistema lança erro
# em qualquer operação que envolva hash de IP ou email.
#
# Rotação: se um salt vazar, gerar novo, atualizar em Vercel, e aceitar
# que hashes antigos ficam órfãos (perda de correlacionabilidade).
NR01_IP_HASH_SALT=
NR01_EMAIL_HASH_SALT=
