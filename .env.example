# Supabase — obter em: https://app.supabase.com → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing NR-01 — CRP do autor (exibir na LP; opcional até divulgação paga)
NEXT_PUBLIC_JOVANE_CRP=

# IA — Groq (geração de texto) + OpenAI (embeddings)
GROQ_API_KEY=sua_groq_api_key_aqui
OPENAI_API_KEY=sua_openai_api_key_aqui

# === Email (NR-01 micro-pulsos) ===
# Sem RESEND_API_KEY, sistema cai em modo 'console' (não envia emails reais).
# Pegar em https://resend.com/api-keys após verificar domínio.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente custom. Default se ausente: 'Quantum5G NR-01 <onboarding@resend.dev>'
# IMPORTANTE: trocar para domínio verificado no Resend antes do primeiro cliente real.
NR01_EMAIL_FROM=

# === NR-01 Pseudonimização (HMAC-SHA256) ===
# Chaves secretas para pseudonimização de IP e email no audit log e tabela
# de convites. Conformidade Art. 13 LGPD (pseudonimização forte).
#
# Gerar localmente com: openssl rand -hex 32
# Adicionar em Vercel: Settings → Environment Variables → Production → Sensitive.
# NUNCA commitar valores reais. Sem essas variáveis, o sistema lança erro
# em qualquer operação que envolva hash de IP ou email.
#
# Rotação: se um salt vazar, gerar novo, atualizar em Vercel, e aceitar
# que hashes antigos ficam órfãos (perda de correlacionabilidade).
NR01_IP_HASH_SALT=
NR01_EMAIL_HASH_SALT=
